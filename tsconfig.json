{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "esModuleInterop": true,
    "declaration": false,
    "sourceMap": false,
    "outDir": ".",
    "rootDir": "src",
    "types": ["tampermonkey", "jquery"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/meta.ts"]
}
